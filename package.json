{
  "name": "discord-bot",
  "version": "1.0.0",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "fix": "biome check --write --unsafe",
    "check": "biome check",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@types/he": "^1.2.3",
    "cron": "^4.1.0",
    "discord.js": "14.27.0",
    "dotenv": "^17.0.0",
    "googleapis": "^171.0.0",
    "he": "^1.2.0",
    "mysql2": "^3.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*": [
      "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "packageManager": "pnpm@11.17.0"
}
